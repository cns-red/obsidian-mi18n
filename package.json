{
  "name": "obsidian-mi18n",
  "version": "1.2.0",
  "repository": {
    "url": "https://github.com/cns-red/obsidian-mi18n"
  },
  "description": "Internationalization for Markdown. Write multiple languages in a single note, then switch the visible language globally.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs",
    "check:i18n": "node scripts/check-i18n.mjs && tsc -noEmit -skipLibCheck",
    "test:syntax": "node scripts/run-syntax-tests.mjs",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "@typescript-eslint/utils": "^8.57.0",
"esbuild": "0.17.3",
    "eslint": "9",
    "globals": "^17.4.0",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "eslint-plugin-obsidianmd": "^0.1.9"
  }
}
